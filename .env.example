# Stripe — get keys from https://dashboard.stripe.com/apikeys
# Use sk_test_/pk_test_ for development, sk_live_/pk_live_ for production.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Site URL (for Stripe redirect URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Adobe Fonts (Typekit) — kit ID for the Flood Std typeface.
# 1) Go to https://fonts.adobe.com/my_fonts and create a Web Project
# 2) Add the "Flood Std" font family to it
# 3) Add this site's domain (e.g. olin.bike, *.vercel.app, localhost)
# 4) Copy the kit ID from the embed snippet (e.g. xyz1abc) and paste here.
# If left empty the brush headings fall back to Caveat.
NEXT_PUBLIC_ADOBE_FONTS_KIT_ID=

# Booking countdown — number shown in the "X spots remaining" counter.
# Update this and redeploy to move the countdown (10 → 9 → 8 …).
NEXT_PUBLIC_SPOTS_REMAINING=6

# Instagram handle (without the @). Used in the footer link.
NEXT_PUBLIC_INSTAGRAM_HANDLE=olincycle
